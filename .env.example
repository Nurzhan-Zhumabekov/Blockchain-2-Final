# ─── RWA Tokenization Platform — Environment Variables ────────────────────────
# Copy to .env and fill in your values.  Never commit .env to git.

# ── Deployer ──────────────────────────────────────────────────────────────────
DEPLOYER_PRIVATE_KEY=0xabc...

# ── RPC endpoints ─────────────────────────────────────────────────────────────
ARBITRUM_SEPOLIA_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# ── Block explorers (for forge --verify) ──────────────────────────────────────
ARBISCAN_API_KEY=your_arbiscan_key_here
BASESCAN_API_KEY=your_basescan_key_here

# ── Chainlink feeds (Arbitrum Sepolia) ────────────────────────────────────────
PRICE_FEED_ADDRESS=0xd30e2101a97dcbAeBCBC04F14C3f624E67A35165
RESERVE_FEED_ADDRESS=0x56a43EB56Da12C0dc1D972ACb089c06a5dEF8e69

# ── Asset config (optional — has defaults in Deploy.s.sol) ───────────────────
ASSET_NAME=US Treasury Bond Token
ASSET_SYMBOL=USTB
ASSET_TYPE=US-TREASURY-BOND

# ── Governance deployment (set after running Deploy.s.sol) ───────────────────
GOV_TOKEN_PROXY=0x...
TIMELOCK_DELAY=172800

# ── V2 upgrade (set after running Deploy.s.sol) ───────────────────────────────
RWA_TOKEN_PROXY=0x...

# ── The Graph (Participant 3) ─────────────────────────────────────────────────
GRAPH_ACCESS_TOKEN=your_graph_studio_token
SUBGRAPH_SLUG=rwa-platform
