# Copy this file to .env and fill in deployed contract addresses.
# All addresses are on Arbitrum Sepolia (chain ID 421614).
# Run script/DeployL2.s.sol to obtain these addresses.

# RPC endpoint (Arbitrum Sepolia public node)
VITE_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc

# The Graph subgraph endpoint (fill in after running: graph deploy --studio rwa-platform)
VITE_SUBGRAPH_URL=https://api.studio.thegraph.com/query/<id>/rwa-platform/version/latest

# Deployed contract addresses (output by DeployL2.s.sol)
VITE_GOV_TOKEN=0x0000000000000000000000000000000000000000
VITE_RWA_TOKEN=0x0000000000000000000000000000000000000000
VITE_RWA_POOL=0x0000000000000000000000000000000000000000
VITE_RWA_STAKING=0x0000000000000000000000000000000000000000
VITE_RWA_GOVERNOR=0x0000000000000000000000000000000000000000
VITE_TIMELOCK=0x0000000000000000000000000000000000000000
VITE_RWA_VAULT=0x0000000000000000000000000000000000000000
